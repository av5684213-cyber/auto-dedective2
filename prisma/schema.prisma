// Otodedektif - Türkiye İkinci El Araç Meta-Arama Platformu

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Listing {
  id              String   @id @default(cuid())
  sourceName      String   @map("source_name")
  sourceUrl       String   @unique @map("source_url")
  vin             String?  @map("vin")
  make            String   @map("make")
  model           String   @map("model")
  trim            String?  @map("trim")
  year            Int      @map("year")
  price           Float    @map("price")
  currency        String   @default("TRY") @map("currency")
  mileageKm       Int?     @map("mileage_km")
  fuelType        String?  @map("fuel_type")
  transmission    String?  @map("transmission")
  bodyType        String?  @map("body_type")
  color           String?  @map("color")
  city            String?  @map("city")
  district        String?  @map("district")
  sellerType      String?  @map("seller_type")
  imageUrl        String?  @map("image_url")
  imageUrls       String   @default("[]") @map("image_urls")
  description     String?  @map("description")
  firstSeenAt     DateTime @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime @default(now()) @map("last_seen_at")
  isActive        Boolean  @default(true) @map("is_active")
  isDeleted       Boolean  @default(false) @map("is_deleted")

  estimatedValue       Float?   @map("estimated_value")
  confidence           String?  @map("confidence")
  dealScore            Float?   @map("deal_score")
  dealTag              String?  @map("deal_tag")
  comparableCount      Int      @default(0) @map("comparable_count")

  annualDepreciationPercent Float? @map("annual_depreciation_percent")
  annualDepreciationAmount   Float? @map("annual_depreciation_amount")
  ownershipCostAnnual        Float? @map("ownership_cost_annual")
  fuelCostAnnual             Float? @map("fuel_cost_annual")
  insuranceCostAnnual        Float? @map("insurance_cost_annual")
  maintenanceCostAnnual      Float? @map("maintenance_cost_annual")
  taxCostAnnual              Float? @map("tax_cost_annual")

  // Fabrika yakıt tüketim verileri (L/100km veya elektrikli için kWh/100km)
  // Kaynak: üretici WLTP/NEDC değerleri; yoksa null bırakılır (component tahmini kullanır).
  fuelConsumptionCity      Float? @map("fuel_consumption_city")
  fuelConsumptionHighway   Float? @map("fuel_consumption_highway")
  fuelConsumptionCombined  Float? @map("fuel_consumption_combined")
  // Enerji tüketim birimi: "L" (litre, ICE/LPG/Hibrit için) ya da "kWh" (elektrikli için)
  fuelConsumptionUnit      String? @default("L") @map("fuel_consumption_unit")
  // Fabrika verisi mi yoksa tahmini mi? ("factory" | "estimated")
  fuelConsumptionSource    String? @default("factory") @map("fuel_consumption_source")

  // ── Bildirim alarmları için ek filtre alanları ────────────────────────────
  // Kazalı durumu: "kazasiz" | "az_hasarli" | "orta_hasarli" | "agir_hasarli" | "belirsiz"
  // Otomatik çıkarım: description'dan keyword match (boyalı, değişen, local, ağır hasar, pert)
  accidentStatus          String?  @map("accident_status")
  // Hasar kaydı detayı (description'dan çıkarılan özet)
  damageInfo              String?  @map("damage_info")

  // ── Katalog eşleştirme ────────────────────────────────────────────────────
  rawMake                 String?  @map("raw_make")
  rawModel                String?  @map("raw_model")
  variantId               String?  @map("variant_id")
  variant                 VehicleVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  matchConfidence         Float?   @map("match_confidence")
  matchStatus             String?  @map("match_status") // matched | unmatched | manual_review

  // ── Esnaf/Galeri (B2B) ────────────────────────────────────────────────────
  dealerId                String?  @map("dealer_id")
  dealer                  Dealer?  @relation(fields: [dealerId], references: [id], onDelete: SetNull)

  // ── Müşteri talepleri (Lead) ──────────────────────────────────────────────
  leads                   Lead[]

  priceHistory    PriceHistory[]
  duplicateGroupId String? @map("duplicate_group_id")

  @@index([sourceName])
  @@index([make, model, year])
  @@index([price])
  @@index([dealTag])
  @@index([dealScore])
  @@index([isActive])
  @@index([mileageKm])
  @@index([year])
  @@index([city])
  @@index([fuelType])
  @@index([color])
  @@index([accidentStatus])
}

model PriceHistory {
  id         String   @id @default(cuid())
  listingId  String   @map("listing_id")
  price      Float    @map("price")
  recordedAt DateTime @default(now()) @map("recorded_at")

  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, recordedAt])
}

model DuplicateGroup {
  id          String   @id @default(cuid())
  listingIds  String   @default("[]") @map("listing_ids")
  primaryId   String?  @map("primary_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
}

model ScrapeLog {
  id          String    @id @default(cuid())
  sourceName  String    @map("source_name")
  startTime   DateTime  @default(now()) @map("start_time")
  endTime     DateTime? @map("end_time")
  status      String    @map("status")
  itemsFound  Int       @default(0) @map("items_found")
  itemsSaved  Int       @default(0) @map("items_saved")
  errorMsg    String?   @map("error_msg")
  durationMs  Int?      @map("duration_ms")
}

model CacheStats {
  id          String    @id @default(cuid())
  key         String    @unique @map("key")
  hitCount    Int       @default(0) @map("hit_count")
  missCount   Int       @default(0) @map("miss_count")
  lastHit     DateTime? @map("last_hit")
  lastMiss    DateTime? @map("last_miss")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String    @map("password_hash")
  role          String    @default("user")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  favorites         UserFavorite[]
  savedSearches     SavedSearch[]
  pushSubscriptions PushSubscription[]
  telegramConnections TelegramConnection[]

  @@map("users")
}

model UserFavorite {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  listingId   String   @map("listing_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("user_favorites")
}

// Fabrika yakıt tüketim referans tablosu — marka/model/yıl/yakıt kombinasyonuna göre
// üretici açıkladığı WLTP/NEDC değerleri. Listing.fuelConsumption* boşsa bu tabloya bakılır.
model VehicleFuelSpec {
  id                  String   @id @default(cuid())
  make                String   @map("make")
  model               String   @map("model")
  // Belirli bir trim/yıl aralığı için olabilir; yearFrom/yearEnd null = tümü
  yearFrom            Int?     @map("year_from")
  yearEnd             Int?     @map("year_end")
  fuelType            String   @map("fuel_type")  // "Benzin" | "Dizel" | "LPG" | "Hybrid" | "Elektrik" | "Benzin + LPG"
  engineDisplacementCc Int?    @map("engine_displacement_cc")
  // Tüketim değerleri — ICE için L/100km, EV için kWh/100km
  consumptionCity     Float?   @map("consumption_city")
  consumptionHighway  Float?   @map("consumption_highway")
  consumptionCombined Float?   @map("consumption_combined")
  unit                String   @default("L") @map("unit") // "L" | "kWh"
  // Veri kaynağı: "WLTP" | "NEDC" | "manufacturer" | "estimated"
  source              String   @default("WLTP") @map("source")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([make, model, yearFrom, yearEnd, fuelType, engineDisplacementCc])
  @@index([make, model])
  @@index([make, model, fuelType])
  @@map("vehicle_fuel_specs")
}

// ── Saved Search Alerts ──────────────────────────────────────────────────
//
// Kullanıcı filtreleri kaydeder. Cron her gece yeni ilanları kontrol eder,
// bu kriterlere uyan yeni ilan varsa email + browser notification gönderir.

model SavedSearch {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  name          String   // kullanıcı verdiği isim, örn "BMW 320i İstanbul 2020+"
  // Filtre kriterleri (JSON olarak saklanır)
  filters       String   @map("filters") // JSON: {make, model, yearMin, yearMax, priceMin, priceMax, fuelType, transmission, city, ...}
  // Bildirim kanalları (eski alanlar — backward compat için duruyor)
  notifyEmail   Boolean  @default(true) @map("notify_email")
  notifyPush    Boolean  @default(true) @map("notify_push")
  // Yeni: coklu kanal destegi — JSON array string olarak saklanir
  channels      String   @default("email,push") @map("channels")
  // Son kontrol zamanı (bu tarihten sonra eklenen ilanları ara)
  lastCheckedAt DateTime @default(now()) @map("last_checked_at")
  // Son bildirim gönderme zamanı
  lastNotifiedAt DateTime? @map("last_notified_at")
  // Eşleşen ilan ID'leri (bildirim gönderilenler — tekrar göndermemek için)
  notifiedListingIds String @default("[]") @map("notified_listing_ids") // JSON array
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications AlertNotification[]

  @@index([userId])
  @@index([isActive])
  @@map("saved_searches")
}

// ── Alert Bildirim Sistemi ────────────────────────────────────────────────
//
// Her kanaldan gönderilen bildirimler — aynı ilan için tekrar göndermeyi önler.
// Cron her gece çalışır, aktif SavedSearch'leri tarar, yeni ilanları bulur,
// bu tabloya kaydeder ve ilgili kanallara (email/push/telegram) paralel gönderir.

model AlertNotification {
  id         String   @id @default(cuid())
  alertId    String   @map("alert_id")
  listingId  String   @map("listing_id")
  channels   String   @default("[]") @map("channels") // JSON array: ["email","push"]
  sentAt     DateTime @default(now()) @map("sent_at")

  alert      SavedSearch @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([alertId, listingId])
  @@index([alertId])
  @@index([listingId])
  @@index([sentAt])
  @@map("alert_notifications")
}

// ── Web Push Subscriptions ────────────────────────────────────────────────
//
// Tarayıcı service worker'dan gelen push subscription objesi saklanır.
// Bir kullanıcının birden çok cihazı olabilir (telefon, masaüstü).

model PushSubscription {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  endpoint     String   @unique
  p256dhKey    String   @map("p256dh_key")
  authKey      String   @map("auth_key")
  // User-agent bilgisi (cihaz tanıma için)
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ── Telegram Bağlantıları ─────────────────────────────────────────────────
//
// Kullanıcı @OtodedektifBot'a /start attığında chat_id buraya kaydedilir.
// Bir kullanıcı sadece 1 Telegram hesabını bağlayabilir (unique user_id).

model TelegramConnection {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  chatId      String   @unique @map("chat_id")
  username    String?  @map("username")
  firstName   String?  @map("first_name")
  connectedAt DateTime @default(now()) @map("connected_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_connections")
}

// ── Araç Kataloğu (Marka → Seri → Varyant) ────────────────────────────────

model VehicleBrand {
  id     String @id @default(cuid())
  name   String @unique
  series VehicleSeries[]
  @@map("vehicle_brands")
}

model VehicleSeries {
  id        String @id @default(cuid())
  brandId   String @map("brand_id")
  brand     VehicleBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name      String
  variants  VehicleVariant[]
  @@unique([brandId, name])
  @@index([brandId])
  @@map("vehicle_series")
}

model VehicleVariant {
  id             String   @id @default(cuid())
  seriesId       String   @map("series_id")
  series         VehicleSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  name           String
  engineCc       Int?     @map("engine_cc")
  powerHp        Int?     @map("power_hp")
  fuelType       String?  @map("fuel_type")
  avgConsumption Float?   @map("avg_consumption")
  source         String   @default("tsb")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  listings       Listing[]
  @@index([seriesId])
  @@index([fuelType])
  @@index([engineCc])
  @@map("vehicle_variants")
}

// ── Müşteri Talepleri (Lead) ──────────────────────────────────────────────

model Lead {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  listingId   String?  @map("listing_id")
  listing     Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  message     String?
  status      String   @default("new") // new | contacted | interested | no_response | converted | lost
  notes       LeadNote[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@index([status])
  @@index([listingId])
  @@index([createdAt])
  @@map("leads")
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String   @map("lead_id")
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  @@index([leadId])
  @@map("lead_notes")
}

// ── Esnaf/Galeri (B2B) ────────────────────────────────────────────────────

model Dealer {
  id                String    @id @default(cuid())
  name              String
  city              String
  phone             String
  email             String?
  subscriptionPlan  String    @default("none") @map("subscription_plan") // none | founder | standard | premium
  subscriptionPrice Float?    @map("subscription_price")
  subscriptionStatus String   @default("inactive") @map("subscription_status") // inactive | active | overdue | cancelled
  lastPaymentDate   DateTime? @map("last_payment_date")
  nextPaymentDue    DateTime? @map("next_payment_due")
  listings          Listing[]
  salesVisits       SalesVisit[]
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  @@index([subscriptionStatus])
  @@index([city])
  @@map("dealers")
}

// ── Saha Satış Takibi ─────────────────────────────────────────────────────

model SalesVisit {
  id          String    @id @default(cuid())
  dealerId    String?   @map("dealer_id")
  dealer      Dealer?   @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  galleryName String?   @map("gallery_name")
  city        String
  contactName String?   @map("contact_name")
  status      String    @default("visited") // planned | visited | negotiating | signed | rejected
  notes       String?
  visitDate   DateTime  @map("visit_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  @@index([status])
  @@index([city])
  @@index([dealerId])
  @@map("sales_visits")
}

// ── Kurumsal Entegrasyon Takibi ───────────────────────────────────────────

model PartnerNegotiation {
  id              String    @id @default(cuid())
  companyName     String    @map("company_name")
  adapterKey      String?   @map("adapter_key")
  status          String    @default("not_started") // not_started | in_negotiation | agreement_signed | integration_active | rejected
  contactName     String?   @map("contact_name")
  contactInfo     String?   @map("contact_info")
  notes           String?
  lastContactDate DateTime? @map("last_contact_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  @@index([status])
  @@index([adapterKey])
  @@map("partner_negotiations")
}
