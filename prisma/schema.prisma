// Otodedektif - Türkiye İkinci El Araç Meta-Arama Platformu

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
}

model Listing {
  id              String   @id @default(cuid())
  sourceName      String   @map("source_name")
  sourceUrl       String   @unique @map("source_url")
  vin             String?  @map("vin")
  make            String   @map("make")
  model           String   @map("model")
  trim            String?  @map("trim")
  year            Int      @map("year")
  price           Float    @map("price")
  currency        String   @default("TRY") @map("currency")
  mileageKm       Int?     @map("mileage_km")
  fuelType        String?  @map("fuel_type")
  transmission    String?  @map("transmission")
  bodyType        String?  @map("body_type")
  color           String?  @map("color")
  city            String?  @map("city")
  district        String?  @map("district")
  sellerType      String?  @map("seller_type")
  imageUrl        String?  @map("image_url")
  imageUrls       String   @default("[]") @map("image_urls")
  description     String?  @map("description")
  firstSeenAt     DateTime @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime @default(now()) @map("last_seen_at")
  isActive        Boolean  @default(true) @map("is_active")
  isDeleted       Boolean  @default(false) @map("is_deleted")

  estimatedValue       Float?   @map("estimated_value")
  confidence           String?  @map("confidence")
  dealScore            Float?   @map("deal_score")
  dealTag              String?  @map("deal_tag")
  comparableCount      Int      @default(0) @map("comparable_count")

  annualDepreciationPercent Float? @map("annual_depreciation_percent")
  annualDepreciationAmount   Float? @map("annual_depreciation_amount")
  ownershipCostAnnual        Float? @map("ownership_cost_annual")
  fuelCostAnnual             Float? @map("fuel_cost_annual")
  insuranceCostAnnual        Float? @map("insurance_cost_annual")
  maintenanceCostAnnual      Float? @map("maintenance_cost_annual")
  taxCostAnnual              Float? @map("tax_cost_annual")

  // Fabrika yakıt tüketim verileri (L/100km veya elektrikli için kWh/100km)
  // Kaynak: üretici WLTP/NEDC değerleri; yoksa null bırakılır (component tahmini kullanır).
  fuelConsumptionCity      Float? @map("fuel_consumption_city")
  fuelConsumptionHighway   Float? @map("fuel_consumption_highway")
  fuelConsumptionCombined  Float? @map("fuel_consumption_combined")
  // Enerji tüketim birimi: "L" (litre, ICE/LPG/Hibrit için) ya da "kWh" (elektrikli için)
  fuelConsumptionUnit      String? @default("L") @map("fuel_consumption_unit")
  // Fabrika verisi mi yoksa tahmini mi? ("factory" | "estimated")
  fuelConsumptionSource    String? @default("factory") @map("fuel_consumption_source")

  priceHistory    PriceHistory[]
  duplicateGroupId String? @map("duplicate_group_id")

  @@index([sourceName])
  @@index([make, model, year])
  @@index([price])
  @@index([dealTag])
  @@index([dealScore])
  @@index([isActive])
  @@index([mileageKm])
  @@index([year])
  @@index([city])
  @@index([fuelType])
}

model PriceHistory {
  id         String   @id @default(cuid())
  listingId  String   @map("listing_id")
  price      Float    @map("price")
  recordedAt DateTime @default(now()) @map("recorded_at")

  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, recordedAt])
}

model DuplicateGroup {
  id          String   @id @default(cuid())
  listingIds  String   @default("[]") @map("listing_ids")
  primaryId   String?  @map("primary_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
}

model ScrapeLog {
  id          String    @id @default(cuid())
  sourceName  String    @map("source_name")
  startTime   DateTime  @default(now()) @map("start_time")
  endTime     DateTime? @map("end_time")
  status      String    @map("status")
  itemsFound  Int       @default(0) @map("items_found")
  itemsSaved  Int       @default(0) @map("items_saved")
  errorMsg    String?   @map("error_msg")
  durationMs  Int?      @map("duration_ms")
}

model CacheStats {
  id          String    @id @default(cuid())
  key         String    @unique @map("key")
  hitCount    Int       @default(0) @map("hit_count")
  missCount   Int       @default(0) @map("miss_count")
  lastHit     DateTime? @map("last_hit")
  lastMiss    DateTime? @map("last_miss")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String    @map("password_hash")
  role          String    @default("user")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  favorites     UserFavorite[]
  savedSearches SavedSearch[]

  @@map("users")
}

model UserFavorite {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  listingId   String   @map("listing_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("user_favorites")
}

// Fabrika yakıt tüketim referans tablosu — marka/model/yıl/yakıt kombinasyonuna göre
// üretici açıkladığı WLTP/NEDC değerleri. Listing.fuelConsumption* boşsa bu tabloya bakılır.
model VehicleFuelSpec {
  id                  String   @id @default(cuid())
  make                String   @map("make")
  model               String   @map("model")
  // Belirli bir trim/yıl aralığı için olabilir; yearFrom/yearEnd null = tümü
  yearFrom            Int?     @map("year_from")
  yearEnd             Int?     @map("year_end")
  fuelType            String   @map("fuel_type")  // "Benzin" | "Dizel" | "LPG" | "Hybrid" | "Elektrik" | "Benzin + LPG"
  engineDisplacementCc Int?    @map("engine_displacement_cc")
  // Tüketim değerleri — ICE için L/100km, EV için kWh/100km
  consumptionCity     Float?   @map("consumption_city")
  consumptionHighway  Float?   @map("consumption_highway")
  consumptionCombined Float?   @map("consumption_combined")
  unit                String   @default("L") @map("unit") // "L" | "kWh"
  // Veri kaynağı: "WLTP" | "NEDC" | "manufacturer" | "estimated"
  source              String   @default("WLTP") @map("source")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([make, model, yearFrom, yearEnd, fuelType, engineDisplacementCc])
  @@index([make, model])
  @@index([make, model, fuelType])
  @@map("vehicle_fuel_specs")
}

// ── Saved Search Alerts ──────────────────────────────────────────────────
//
// Kullanıcı filtreleri kaydeder. Cron her gece yeni ilanları kontrol eder,
// bu kriterlere uyan yeni ilan varsa email + browser notification gönderir.

model SavedSearch {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  name          String   // kullanıcı verdiği isim, örn "BMW 320i İstanbul 2020+"
  // Filtre kriterleri (JSON olarak saklanır)
  filters       String   @map("filters") // JSON: {make, model, yearMin, yearMax, priceMin, priceMax, fuelType, transmission, city, ...}
  // Bildirim ayarları
  notifyEmail   Boolean  @default(true) @map("notify_email")
  notifyPush    Boolean  @default(true) @map("notify_push")
  // Son kontrol zamanı (bu tarihten sonra eklenen ilanları ara)
  lastCheckedAt DateTime @default(now()) @map("last_checked_at")
  // Eşleşen ilan ID'leri (bildirim gönderilenler — tekrar göndermemek için)
  notifiedListingIds String @default("[]") @map("notified_listing_ids") // JSON array
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("saved_searches")
}
